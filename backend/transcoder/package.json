{
  "name": "cliquepix-transcoder",
  "version": "0.1.0",
  "description": "CliquePix video transcoder — Container Apps Job that processes transcoding requests via FFmpeg",
  "main": "dist/runner.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "transcode-local": "npm run build && bash scripts/transcode-local.sh"
  },
  "dependencies": {
    "@azure/identity": "^4.2.0",
    "@azure/storage-blob": "^12.17.0",
    "@azure/storage-queue": "^12.24.0",
    "applicationinsights": "^2.9.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
