<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!-- 5-Layer Token Refresh Permissions -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Suppress exact-alarm permissions. The Friday reminder uses
         AndroidScheduleMode.inexactAllowWhileIdle which does not need either
         permission. The flutter_local_notifications plugin declares these
         transitively in its own manifest; tools:node="remove" actively
         removes them during manifest merge. USE_EXACT_ALARM is restricted by
         Google Play policy to alarm-clock / calendar apps only — CLIQUE Pix
         is neither. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:node="remove" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"
        tools:node="remove" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Camera, Audio & Media -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Push Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:label="CLIQUE Pix"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Deep Links: App Links for clique-pix.com -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="clique-pix.com"
                    android:pathPrefix="/invite" />
            </intent-filter>
        </activity>

        <!-- MSAL browser redirect for Entra External ID auth.

             Each <data> path is base64(SHA1(signing cert)) for one build's cert.
             BOTH are registered so the auth-callback redirect is caught whichever
             cert signs the running build:
               /4FsaiJ4wJWgM09R/hUh3osYJhgg=  → RELEASE / Play App Signing key
               /W28+gAaZ9fNu1yL/GMRe94rK0dY=  → DEBUG keystore (local dev)
             The redirect_uri MSAL actually SENDS is chosen at build time by
             MsalConstants.androidRedirectUri (String.fromEnvironment; defaults to
             the release hash, debug opts in via the dart-define-from-file
             build flag (dart_defines/debug.json). Both hashes must
             also be registered as redirect URIs in the Entra app registration
             (7db01206-135b-4a34-a4d5-2622d1a888bf).
             Regenerate the release hash from the Play App Signing cert:
               Play Console > Protected with Play > Play Store protection >
               Protect app signing key > Manage Play app signing  → download cert →
               openssl sha1 -binary <cert.der> | openssl base64
             See docs/SECURITY_AUDIT_2026-06-04.md (AUTH-1 / H4). -->
        <activity
            android:name="com.microsoft.identity.client.BrowserTabActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- RELEASE / Play App Signing key cert hash -->
                <data
                    android:host="com.cliquepix.clique_pix"
                    android:path="/4FsaiJ4wJWgM09R/hUh3osYJhgg="
                    android:scheme="msauth" />
                <!-- DEBUG keystore cert hash (local dev) -->
                <data
                    android:host="com.cliquepix.clique_pix"
                    android:path="/W28+gAaZ9fNu1yL/GMRe94rK0dY="
                    android:scheme="msauth" />
            </intent-filter>
        </activity>

        <!-- FCM default notification channel -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="cliquepix_default" />

        <!-- Don't auto-init Firebase (we do it in Dart) -->
        <meta-data
            android:name="firebase_messaging_auto_init_enabled"
            android:value="false" />
        <meta-data
            android:name="firebase_analytics_collection_enabled"
            android:value="false" />

        <!-- Flutter v2 embedding -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- image_cropper's uCrop backend (avatar square-crop UI). Custom dark theme
             defined in res/values/styles.xml — fixes top-icon clipping, dark/light
             theme contrast, and gesture-nav inset handling on modern Android. -->
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:screenOrientation="portrait"
            android:theme="@style/UCropTheme" />

    </application>

    <!-- Required for file provider (image_picker) and url_launcher scheme resolution -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <!-- Required for url_launcher to resolve mailto: on Android 11+ (API 30+) -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
    </queries>

</manifest>
