# Clique Pix web client — environment variables.
# All VITE_*-prefixed vars are baked into the client bundle at build time.
# Do NOT put secrets here. These are all public OAuth/MSAL/API identifiers.

VITE_API_BASE_URL=https://api.clique-pix.com
VITE_MSAL_CLIENT_ID=7db01206-135b-4a34-a4d5-2622d1a888bf
VITE_MSAL_AUTHORITY=https://cliquepix.ciamlogin.com/cliquepix.onmicrosoft.com/
VITE_MSAL_KNOWN_AUTHORITY=cliquepix.ciamlogin.com
VITE_MSAL_SCOPE=api://7db01206-135b-4a34-a4d5-2622d1a888bf/access_as_user

# Optional: Application Insights RUM. Populate with the connection string
# from the appi-cliquepix-prod resource. Leave blank to disable RUM.
VITE_APPLICATION_INSIGHTS_CONNECTION_STRING=
