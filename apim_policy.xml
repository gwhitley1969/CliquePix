<policies>
	<inbound>
		<base />
		<cors allow-credentials="false">
			<allowed-origins>
				<origin>https://clique-pix.com</origin>
				<origin>http://localhost:5173</origin>
			</allowed-origins>
			<allowed-methods preflight-result-max-age="3600">
				<method>GET</method>
				<method>POST</method>
				<method>PUT</method>
				<method>PATCH</method>
				<method>DELETE</method>
				<method>OPTIONS</method>
			</allowed-methods>
			<allowed-headers>
				<header>*</header>
			</allowed-headers>
			<expose-headers>
				<header>x-request-id</header>
			</expose-headers>
		</cors>
		<rate-limit-by-key calls="60" renewal-period="60" counter-key="@(context.Request.IpAddress)" />
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>